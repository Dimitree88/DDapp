# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# local database (libSQL/SQLite dev file)
local.db
local.db-*
*.db

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# claude code (impostazioni locali/personali)
.claude/settings.local.json

# asset sorgente pesanti (l'app usa public/background.webp)
/images/

# materiale di riferimento (manuali PDF, non da pubblicare)
/references/

# log di lavoro temporanei
*.log
